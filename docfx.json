{
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": [
            "**/*.csproj"
          ]
        }
      ],
      "dest": "api",
      "outputFormat": "apiPage"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "articles/**.md",
          "articles/**/toc.yml",
          "toc.yml",
          "*.md",
          "api/**.md",
          "api/**/toc.yml"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "**/media/**"
        ]
      }
    ],
    "markdownEngineName": "markdig",
    "dest": "_site",
    "globalMetadataFiles": [],
    "fileMetadataFiles": [],
    "template": [
      "default",
      "modern",
      "./themes/material",
      "./themes/material-classic"
    ],
    "postProcessors": [
      "ExtractSearchIndex"
    ],
    "globalMetadata": {
      "_appFooter": "<span>Copyright © 2023 Oscar Vasquez. Generated with <a href=\"https://dotnet.github.io/docfx\">DocFX</a></span>",
      "_appName": "Manager Datafiles",
      "_appTitle": "Manager Datafiles",
      "_appLogoPath": "images/code.svg",
      "_appFaviconPath": "images/favicon.svg",
      "_googleAnalyticsTagId": "G-Q5N6XJHEX5",
      "_enableSearch": "true",
      "_gitContribute": {
        "repo": "https://github.com/ovasquez/docfx-material"
      },
      "_gitUrlPattern": "github",
      "pdf": true
    },
    "noLangKeyword": false,
    "keepFileLink": false,
    "cleanupCacheHistory": false,
    "disableGitFeatures": false,
    "sitemap": {
      "baseUrl": "https://github.com/nqdev-storage/docfx-manager-datafiles",
      "priority": 0.1,
      "changefreq": "daily"
    },
    "markdownEngineProperties": {
      "markdigExtensions": [
        "Abbreviations",
        "Footnotes"
      ],
      "alerts": {
        "TODO": "alert alert-secondary"
      },
      "plantUml": {
        "outputFormat": "svg",
        "remoteUrl": "http://www.plantuml.com/plantuml/",
        "renderingMode": "remote"
      }
    }
  },
  "pdf": {}
}