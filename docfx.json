{
  "metadata": [
    {
      "src": [
        {
          "src": "../src",
          "files": [
            "**/*.csproj"
          ]
        }
      ],
      "dest": "api",
      "outputFormat": "apiPage"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "**/*.{md,yml}"
        ],
        "exclude": [
          "_site/**",
          "obj/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**",
          "**/media/**",
          "codesnippet/**"
        ],
        "exclude": [
          "_site/**",
          "obj/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern",
      "template"
    ],
    "globalMetadata": {
      "_appName": "manager-datafiles",
      "_appTitle": "manager-datafiles",
      "_enableSearch": true,
      "pdf": true,
      "_googleAnalyticsTagId": "G-Q5N6XJHEX5",
      "_appFooter": "<span>Supported by the <a href=\"https://dotnetfoundation.org\">.NET Foundation</a>. Made with <a href=\"https://dotnet.github.io/docfx\">docfx</a></span>"
    },
    "markdownEngineProperties": {
      "alerts": {
        "TODO": "alert alert-secondary"
      }
    },
    "sitemap": {
      "baseUrl": "https://github.com/nqdev-storage/docfx-manager-datafiles",
      "priority": 0.5,
      "changefreq": "daily"
    }
  }
}